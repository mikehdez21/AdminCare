{
  "version": 2,
  "framework": "vite",
  "installCommand": "cd frontend && npm ci",
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://admincare-production.up.railway.app/api/$1"
    },
    {
      "src": "/sanctum/csrf-cookie",
      "dest": "https://admincare-production.up.railway.app/sanctum/csrf-cookie"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/((?!api/|sanctum/|assets/).*)",
      "dest": "/index.html"
    }
  ]
}
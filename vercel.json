{
  "version": 2,
  "framework": "vite",
  "installCommand": "cd frontend && npm ci",
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "public/build",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://admincare-production.up.railway.app/api/$1"
    },
    {
      "source": "/sanctum/csrf-cookie",
      "destination": "https://admincare-production.up.railway.app/sanctum/csrf-cookie"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
{
  "compilerOptions": {
    /* Configuraciones comunes */
    "target": "ES2022", // Compatibilidad con ES2022 (puedes elegir entre ES2020 y ES2022)
    "useDefineForClassFields": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable"], // Incluye librerías comunes de DOM y ES2023
    "module": "ESNext", // Uso de módulos ESNext
    "skipLibCheck": true, // Omitir verificación de tipos en bibliotecas

    /* Modo Bundler */
    "moduleResolution": "bundler", // Resolución de módulos estilo bundler
    "allowImportingTsExtensions": true, // Permitir importar archivos con extensiones TS
    "isolatedModules": true, // Aislar módulos para evitar problemas de compilación
    "moduleDetection": "force", // Forzar la detección de módulos
    "noEmit": true, // No emitir archivos de salida
    "jsx": "react-jsx", // JSX para React

    /* Linting */
    "strict": true, // Activar modo estricto de TypeScript
    "noUnusedLocals": true, // Advertir sobre variables no usadas
    "noUnusedParameters": true, // Advertir sobre parámetros no usados
    "noFallthroughCasesInSwitch": true, // Evitar caídas en declaraciones switch

    /* Paths y resolución */
    "baseUrl": ".", // Define la raíz del proyecto
    "paths": {
      "@/*": ["src/js/*"], // Alias para directorios comunes
      "@styles/*": ["src/css/*"]
    }
  },
  "include": [
    "src/**/*", // Incluir todo en el directorio de 'resources'
    "vite.config.ts" // Incluir el archivo de configuración de Vite
  ],
  "exclude": [
    "node_modules", // Excluir node_modules
    "dist" // Excluir directorios de salida
  ]
}
